#!/usr/bin/env python3
"""Bounded deterministic audio descriptors for one transient analysis WAV."""

import json
import math
import pathlib
import sys

import essentia
import essentia.standard as es
import numpy as np


def finite(value):
    number = float(value)
    return round(number, 4) if math.isfinite(number) else None


def main():
    if len(sys.argv) != 2:
        raise RuntimeError("exactly one analysis WAV path is required")
    path = pathlib.Path(sys.argv[1]).resolve(strict=True)
    if not path.is_file() or path.is_symlink() or path.suffix.lower() != ".wav":
        raise RuntimeError("analysis input must be one regular WAV file")
    if path.stat().st_size > 200 * 1024 * 1024:
        raise RuntimeError("analysis WAV exceeds 200 MiB")

    audio = es.MonoLoader(filename=str(path), sampleRate=44100)()
    if len(audio) < 44100:
        raise RuntimeError("analysis audio is too short")
    bpm, beats, confidence, estimates, intervals = es.RhythmExtractor2013(method="multifeature")(audio)
    key, scale, key_strength = es.KeyExtractor()(audio)
    dynamic_complexity, loudness = es.DynamicComplexity()(audio)
    danceability, dfa = es.Danceability()(audio)

    segments = []
    for index, block in enumerate(np.array_split(audio, 8), start=1):
        rms = math.sqrt(float(np.mean(np.square(block, dtype=np.float64)))) if len(block) else 0.0
        segments.append(f"segment {index}: RMS {finite(rms)}")

    alternatives = []
    for estimate in list(estimates)[:8]:
        value = finite(estimate)
        if value and 20 <= value <= 400 and abs(value - float(bpm)) >= 0.5 and value not in alternatives:
            alternatives.append(value)

    result = {
        "schema_version": "soul.music.reference.extractor.v1",
        "essentia_version": getattr(essentia, "__version__", "unknown"),
        "bpm": finite(bpm),
        "bpm_alternatives": alternatives[:5],
        "rhythm_confidence": finite(confidence),
        "beat_count": len(beats),
        "median_beat_interval": finite(np.median(intervals)) if len(intervals) else None,
        "key": f"{key} {scale}",
        "key_strength": finite(key_strength),
        "dynamic_complexity": finite(dynamic_complexity),
        "loudness": finite(loudness),
        "danceability": finite(danceability),
        "dfa": finite(np.mean(dfa)) if len(dfa) else None,
        "energy_curve": segments,
    }
    print(json.dumps(result, separators=(",", ":")))


if __name__ == "__main__":
    try:
        main()
    except Exception as error:
        print(f"analysis failed: {error}", file=sys.stderr)
        sys.exit(1)
