{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://soul.local/schema/music_candidate_review.v1.json",
  "title": "Soul Music Candidate Review",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "project_id", "candidate_id", "rating", "disposition", "musical_quality", "prompt_adherence", "vocal_adherence", "lyric_adherence", "notes", "reviewed_at"],
  "properties": {
    "schema_version": { "const": "soul.music.candidate_review.v1" },
    "project_id": { "type": "string", "pattern": "^music_[a-f0-9]{16}$" },
    "candidate_id": { "type": "string", "pattern": "^candidate_[a-f0-9]{16}$" },
    "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
    "disposition": { "enum": ["keep", "revise", "reject"] },
    "musical_quality": { "enum": ["passed", "partial", "failed", "not_applicable"] },
    "prompt_adherence": { "enum": ["passed", "partial", "failed", "not_applicable"] },
    "vocal_adherence": { "enum": ["passed", "partial", "failed", "not_applicable"] },
    "lyric_adherence": { "enum": ["passed", "partial", "failed", "not_applicable"] },
    "notes": { "type": "string", "maxLength": 8000 },
    "reviewed_at": { "type": "string", "format": "date-time" }
  }
}
