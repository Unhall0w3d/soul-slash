# Soul/ portable local configuration template.
#
# Copy this file to `.env` and set only values needed on this machine.
# `.env` is ignored by git. Never commit credentials.
# Inspect the effective typed configuration with:
#   ruby bin/soul config show
# Validate it with:
#   ruby bin/soul config validate

# Preferred conversation provider. Leave blank to select the first configured
# eligible local provider.
# Values: local.openai_compatible, local.ollama, cloud.openai_compatible
SOUL_CONVERSATION_PROVIDER=
SOUL_CONVERSATION_MODE=auto
SOUL_ALLOW_CLOUD_CONVERSATION=false

# Conversation bounds.
SOUL_CONVERSATION_MAX_MESSAGES=12
SOUL_CONVERSATION_MAX_CHARACTERS=24000
SOUL_CONVERSATION_MAX_TOOL_STEPS=4
SOUL_CONVERSATION_TEMPERATURE=0.65
SOUL_CONVERSATION_MAX_OUTPUT_TOKENS=1024
SOUL_CONVERSATION_TIMEOUT_SECONDS=120

# Local OpenAI-compatible provider, including llama.cpp servers.
# Set the model identifier exposed by your own server.
SOUL_LOCAL_OPENAI_BASE_URL=http://127.0.0.1:8082/v1
SOUL_LOCAL_OPENAI_MODEL=

# Optional authenticated dashboard control for existing allowlisted systemd user
# model services. Without a private profiles file, the single-service values
# remain compatible. This never installs or enables a service and has no
# automatic load, unload, or switch behavior. llama.cpp must expose /slots.
SOUL_MODEL_RUNTIME_CONTROL=0
SOUL_MODEL_RUNTIME_SERVICE=llama-server.service
SOUL_MODEL_RUNTIME_SLOTS_URL=http://127.0.0.1:8082/slots
SOUL_MODEL_RUNTIME_PROFILE=nvidia-fallback
SOUL_MODEL_RUNTIME_PROFILES_FILE=

# Local Ollama provider. Set the model installed on your own machine.
OLLAMA_HOST=http://127.0.0.1:11434
SOUL_OLLAMA_MODEL=

# Optional cloud OpenAI-compatible provider. Credentials belong only in the
# ignored `.env` or process environment. Credential presence does not enable
# cloud conversation; SOUL_ALLOW_CLOUD_CONVERSATION must also be true.
SOUL_CLOUD_OPENAI_BASE_URL=
SOUL_CLOUD_OPENAI_MODEL=
SOUL_CLOUD_OPENAI_CREDENTIAL_ENV=SOUL_CLOUD_OPENAI_API_KEY
# SOUL_CLOUD_OPENAI_API_KEY=

# Bounded artifact creation.
SOUL_ARTIFACT_APPROVAL_TTL_SECONDS=900
SOUL_ARTIFACT_MAX_OUTPUT_TOKENS=4096

# Optional bounded public-web research. DuckDuckGo Instant Answer lookup needs
# no configuration and is used only for narrow orientation. Deeper research
# uses the selected provider. SearXNG may use loopback HTTP, or the exact private
# LAN endpoint when SOUL_WEB_ALLOW_PRIVATE_SEARXNG=true. Public endpoints require
# HTTPS. Provider addresses and credentials remain only in `.env`.
# Values: searxng, brave
SOUL_WEB_SEARCH_PROVIDER=
SOUL_WEB_SEARXNG_URL=
SOUL_WEB_ALLOW_PRIVATE_SEARXNG=false
# SOUL_WEB_BRAVE_API_KEY=

# Reserved for the future separately approved foreground dashboard. These
# values do not start a listener. Phase 12 accepts loopback binding only.
SOUL_DASHBOARD_BIND_HOST=127.0.0.1
SOUL_DASHBOARD_PORT=4567
# Optional exact HTTPS reverse-proxy origin. This does not widen Soul's bind.
SOUL_DASHBOARD_PUBLIC_ORIGIN=

# Existing foreground local-model setup scripts also consume the following
# compatibility values. Choose a provider and supply model file/URL values only
# when using those scripts. Relative model storage remains machine-portable.
# Values: llamacpp, ollama
SOUL_RUNTIME_PROVIDER=
SOUL_OPENAI_BASE_URL=http://127.0.0.1:8082/v1
SOUL_MODEL_ALIAS=
SOUL_MODEL_DIR=./models
SOUL_MODEL_FILE=
SOUL_MODEL_URL=
SOUL_LLAMA_HOST=127.0.0.1
SOUL_LLAMA_PORT=8082
SOUL_CTX_SIZE=4096
SOUL_N_PREDICT=2048
SOUL_GPU_LAYERS=999
SOUL_CACHE_TYPE_K=f16
SOUL_CACHE_TYPE_V=f16
SOUL_FLASH_ATTN=off
SOUL_REASONING_FORMAT=deepseek
SOUL_USE_JINJA=true
