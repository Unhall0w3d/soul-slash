# Soul/ local runtime configuration template.
#
# Copy this file to `.env` and adjust values for your local runtime.
#
# .env is intentionally ignored by git.

# Runtime provider.
# Supported values:
#   llamacpp
#   ollama
SOUL_RUNTIME_PROVIDER=llamacpp

# OpenAI-compatible API base URL.
#
# llama.cpp tested default:
#   http://127.0.0.1:8082/v1
#
# Ollama default:
#   http://127.0.0.1:11434/v1
SOUL_OPENAI_BASE_URL=http://127.0.0.1:8082/v1

# Model identifier used by Soul/ when calling the OpenAI-compatible endpoint.
#
# llama.cpp tested default:
#   soul-qwen3-8b-q4
#
# Ollama example:
#   qwen3:8b
SOUL_MODEL_ALIAS=soul-qwen3-8b-q4

# llama.cpp-only GGUF setup values.
SOUL_MODEL_DIR=./models
SOUL_MODEL_FILE=Qwen3-8B-Q4_K_M.gguf
SOUL_MODEL_URL=https://huggingface.co/Qwen/Qwen3-8B-GGUF/resolve/main/Qwen3-8B-Q4_K_M.gguf?download=true

# llama.cpp tested defaults.
SOUL_LLAMA_HOST=127.0.0.1
SOUL_LLAMA_PORT=8082
SOUL_CTX_SIZE=4096
SOUL_N_PREDICT=2048
SOUL_GPU_LAYERS=999
SOUL_CACHE_TYPE_K=f16
SOUL_CACHE_TYPE_V=f16
SOUL_FLASH_ATTN=off
SOUL_REASONING_FORMAT=deepseek
SOUL_USE_JINJA=true

# Ollama setup value.
SOUL_OLLAMA_MODEL=qwen3:8b
