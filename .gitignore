
# Soul/ local-only configuration
.env
.env.*
!.env.example
.envrc
*.local
*.local.*
*.local.yaml
*.secret
*.secret.*
secrets/

# Local runtime artifacts
run/
tmp/
cache/
.cache/
logs/
*.log

# Soul/ generated logs, state, workflow sessions, and reflection drafts
Soul/logs/tasks/*.json
Soul/logs/tool_runs/*.json
Soul/workflows/pending/*.json
Soul/workflows/sessions/*.json
Soul/reflection/pending/*.json
Soul/reflection/pending/*.md
Soul/reflection/approved/*.json
Soul/reflection/approved/*.md
Soul/reflection/rejected/*.json
Soul/reflection/rejected/*.md

# Keep directory sentinels
!Soul/logs/tasks/.keep
!Soul/logs/tool_runs/.keep
!Soul/workflows/pending/.keep
!Soul/workflows/sessions/.keep
!Soul/reflection/pending/.keep
!Soul/reflection/approved/.keep
!Soul/reflection/rejected/.keep

# Soul/ generated improvement, alpha, and runtime assessment state
Soul/improvement/proposals/*
!Soul/improvement/proposals/.keep
Soul/runtime/*.json
Soul/runtime/*.tmp
Soul/runtime/*.log
!Soul/runtime/.keep
Soul/runtime/
# Local model files and model directories
models/
*.gguf
*.safetensors
*.bin
*.pth
*.pt
*.onnx
*.tflite

# Generated overlay/package artifacts
*.zip
*_overlay/
*_overlay.zip
soul_*_overlay/
soul_*_overlay.zip
overlay_files/

# Overlay instruction notes are temporary unless deliberately curated
README_*PHASE*.md
README_*REPAIR*.md
/README_*.md
docs/overlays/README_*PHASE*.md
docs/overlays/README_*REPAIR*.md

# Temporary backup files
*.bak
*.backup
*.backup-*
*.orig
*.rej

# Ruby/local dependency artifacts
.bundle/
vendor/bundle/
coverage/

# Python/local helper artifacts
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/

# Editor/OS cruft
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# Soul/ local cloud provider configuration.
# Keep the example tracked, keep real provider enablement local.
Soul/config/cloud_providers.yaml
!Soul/config/cloud_providers.example.yaml

# Soul/ cloud-assisted generated artifacts and skill proposals.
# Generated artifacts are local/review-only unless manually promoted.
Soul/artifacts/cloud_assist/*
!Soul/artifacts/cloud_assist/.keep
Soul/proposals/skills/*
!Soul/proposals/skills/.keep

# One-time overlay patch scripts should not be committed after application.
scripts/patch-*.rb
scripts/repair-*.rb

# Soul local runtime data
# These files may contain private chats, local memory, credentials-adjacent metadata,
# runtime databases, generated task state, and machine-specific artifacts.
Soul/runtime/
Soul/codex/tasks/
Soul/codex/responses/
Soul/codex/reviews/
*.soul.local
